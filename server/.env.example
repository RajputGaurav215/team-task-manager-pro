# Local PostgreSQL database URL. If you use the included Docker PostgreSQL, keep this as-is.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team_task_manager?schema=public"

# JWT secret for local development. Change this in production/Railway.
JWT_SECRET="local-super-secret-change-in-production"

# React dev server URL for CORS in local development.
CLIENT_URL="http://localhost:5173"

# Backend local port. Railway provides PORT automatically in production.
PORT=5000
